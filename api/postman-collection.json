            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Discounted Shoes\",\n  \"price\": 1000,\n  \"category\": \"Clothes\",\n  \"description\": \"Nice shoes.\",\n  \"seller\": \"Shoe Store\",\n  \"postedDate\": \"2026-01-01\",\n  \"priceDiscount\": 1500\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "http://localhost:3000/api/v1/products",
              "protocol": "http",
              "host": ["localhost"],
              "port": "3000",
              "path": ["api", "v1", "products"]
            }
          }
        },
