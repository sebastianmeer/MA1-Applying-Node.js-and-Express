    },
    {
      "name": "GT2D - Error Handling",
      "item": [
        {
          "name": "Handle Invalid DB ID - Incorrect ID Format",
          "request": {
            "method": "GET",
            "url": {
              "raw": "http://localhost:3000/api/v1/products/12345",
              "protocol": "http",
              "host": ["localhost"],
              "port": "3000",
              "path": ["api", "v1", "products", "12345"]
            }
          }
        },
        {
          "name": "Handle Invalid DB ID - Correct Format but Does Not Exist",
          "request": {
            "method": "GET",
            "url": {
              "raw": "http://localhost:3000/api/v1/products/000fa2c3c4d5e6f7a8b9c0d0",
              "protocol": "http",
              "host": ["localhost"],
              "port": "3000",
              "path": ["api", "v1", "products", "000fa2c3c4d5e6f7a8b9c0d0"]
            }
          }
        },
        {
          "name": "Handle Duplicate DB Field - Duplicate Product Name",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Second-hand Laptop\",\n  \"price\": 15000,\n  \"category\": \"Electronics\",\n  \"seller\": \"Juan Dela Cruz\",\n  \"postedDate\": \"2026-01-01\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "http://localhost:3000/api/v1/products",
              "protocol": "http",
              "host": ["localhost"],
              "port": "3000",
              "path": ["api", "v1", "products"]
            }
          }
        },
        {
          "name": "Handle Mongoose Validation Error - Missing Price & Long Description",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"A Brand New Test Product\",\n  \"category\": \"Books\",\n  \"seller\": \"Keith\",\n  \"postedDate\": \"2026-01-01\",\n  \"description\": \"This description is intentionally made to be very long so that it exceeds the fifty character maximum limit we set in the schema.\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "http://localhost:3000/api/v1/products",
              "protocol": "http",
              "host": ["localhost"],
              "port": "3000",
              "path": ["api", "v1", "products"]
            }
          }
        },
        {
          "name": "Uncaught Exception - Trigger ReferenceError (GET /products/)",
          "request": {
            "method": "GET",
            "description": "This triggers an uncaught exception if the controller references an undefined variable (e.g., 'x is not defined'). Requires a deliberate bug in the controller for testing.",
            "url": {
              "raw": "http://localhost:3000/api/v1/products/",
              "protocol": "http",
              "host": ["localhost"],
              "port": "3000",
              "path": ["api", "v1", "products", ""]
            }
          }
        }
      ]
    }
  ]
}
