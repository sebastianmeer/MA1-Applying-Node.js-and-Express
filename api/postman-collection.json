            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Luxury Gold Watch\",\n  \"price\": 50000,\n  \"category\": \"Clothes\",\n  \"description\": \"18k gold plated.\",\n  \"seller\": \"Classy Finds\",\n  \"postedDate\": \"2024-01-10T00:00:00.000Z\",\n  \"premiumProducts\": true\n}",
              "options": { "raw": { "language": "json" } }
